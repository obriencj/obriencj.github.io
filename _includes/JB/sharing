{% if page.sharing != false and site.JB.sharing %}
<ul class="sharing">
   {% if site.JB.sharing.twitter %}
      <li class="sharing">
      {% include JB/sharing-providers/twitter %}
      </li>
   {% endif %}
   {% if site.JB.sharing.googleplus %}
      <li class="sharing">
      {% include JB/sharing-providers/googleplus %}
      </li>
   {% endif %}
</ul>
{% endif %}
